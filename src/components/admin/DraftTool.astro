---
---

<section
    id="tab-draft"
    class="tab-content hidden w-full flex-1 flex flex-col p-10"
>
    <div class="flex items-center gap-3.5 mb-8 pb-6 border-b border-uu-sub/20">
        <div
            class="w-10 h-10 rounded-full bg-uu-sub/10 flex items-center justify-center text-uu-main"
        >
            <span class="material-symbols-outlined">auto_fix</span>
        </div>
        <h3 class="font-bold text-xl text-uu-dark">文章草稿工具</h3>
    </div>

    <div class="space-y-8 flex-1 overflow-y-auto pr-4 no-scrollbar">
        <div class="grid grid-cols-1 gap-6">
            <div class="space-y-2">
                <label
                    class="text-[10px] font-black text-uu-main/40 uppercase tracking-widest"
                    >1. 文章暫定標題或主題方向</label
                >
                <input
                    id="draft-q1"
                    type="text"
                    class="w-full bg-uu-base/20 border border-uu-sub/20 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-uu-main transition-all"
                    placeholder="請在此填寫"
                />
            </div>
            <div class="space-y-2">
                <label
                    class="text-[10px] font-black text-uu-main/40 uppercase tracking-widest"
                    >2. 目標受眾（這篇文章寫給誰看）</label
                >
                <input
                    id="draft-q2"
                    type="text"
                    class="w-full bg-uu-base/20 border border-uu-sub/20 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-uu-main transition-all"
                    placeholder="請在此填寫"
                />
            </div>
            <div class="space-y-2">
                <label
                    class="text-[10px] font-black text-uu-main/40 uppercase tracking-widest"
                    >3. 核心觀點與目的</label
                >
                <input
                    id="draft-q3"
                    type="text"
                    class="w-full bg-uu-base/20 border border-uu-sub/20 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-uu-main transition-all"
                    placeholder="讀完這篇文章，讀者能帶走什麼？"
                />
            </div>
            <div class="space-y-2">
                <label
                    class="text-[10px] font-black text-uu-main/40 uppercase tracking-widest"
                    >4. 關鍵段落與大綱（列出 3-5 個重點）</label
                >
                <textarea
                    id="draft-q4"
                    class="w-full bg-uu-base/20 border border-uu-sub/20 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-uu-main transition-all min-h-[120px]"
                    placeholder="- 重點 1：
- 重點 2：
- 重點 3："></textarea>
            </div>
            <div class="space-y-2">
                <label
                    class="text-[10px] font-black text-uu-main/40 uppercase tracking-widest"
                    >5. 個人獨特經驗與細節（文章的靈魂）</label
                >
                <textarea
                    id="draft-q5"
                    class="w-full bg-uu-base/20 border border-uu-sub/20 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-uu-main transition-all min-h-[150px]"
                    placeholder="請在此填寫你想放入的具體細節"></textarea>
            </div>
            <div class="space-y-2">
                <label
                    class="text-[10px] font-black text-uu-main/40 uppercase tracking-widest"
                    >6. 行文語氣與風格</label
                >
                <input
                    id="draft-q6"
                    type="text"
                    class="w-full bg-uu-base/20 border border-uu-sub/20 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-uu-main transition-all"
                    placeholder="預設：輕鬆幽默的個人隨筆"
                />
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div class="space-y-2">
                    <label
                        class="text-[10px] font-black text-uu-main/40 uppercase tracking-widest"
                        >文章短網址 (Slug)</label
                    >
                    <input
                        id="draft-slug"
                        type="text"
                        class="w-full bg-uu-base/20 border border-uu-sub/20 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-uu-main transition-all"
                        placeholder="例如: 2024-trip"
                    />
                </div>
                <div class="space-y-2">
                    <label
                        class="text-[10px] font-black text-uu-main/40 uppercase tracking-widest"
                        >分類 (Category)</label
                    >
                    <input
                        id="draft-cat"
                        type="text"
                        class="w-full bg-uu-base/20 border border-uu-sub/20 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-uu-main transition-all"
                        placeholder="例如：生活隨筆"
                    />
                </div>
                <div class="space-y-2">
                    <label
                        class="text-[10px] font-black text-uu-main/40 uppercase tracking-widest"
                        >標籤 (Tags)</label
                    >
                    <input
                        id="draft-tags"
                        type="text"
                        class="w-full bg-uu-base/20 border border-uu-sub/20 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-uu-main transition-all"
                        placeholder="用逗號分隔"
                    />
                </div>
            </div>
        </div>

        <div
            class="space-y-2 mt-6 p-6 bg-uu-main/5 rounded-2xl border border-uu-main/10 shadow-inner"
        >
            <div class="flex items-center justify-between mb-2">
                <label
                    class="text-[10px] font-black text-uu-main uppercase tracking-widest flex items-center gap-2"
                >
                    <span class="material-symbols-outlined text-sm"
                        >settings_suggest</span
                    >
                    進階：編輯預設指令模板 (Prompt Template)
                </label>
                <button
                    id="save-template-btn"
                    class="flex items-center gap-1.5 px-3 py-1 bg-white border border-uu-main/20 text-uu-main rounded-lg text-[10px] font-black tracking-widest uppercase hover:bg-uu-main hover:text-white transition-all shadow-sm"
                >
                    <span class="material-symbols-outlined text-xs"
                        >cloud_upload</span
                    >
                    儲存到資料庫
                </button>
            </div>
            <textarea
                id="draft-template"
                class="w-full bg-white border border-uu-sub/20 rounded-xl px-4 py-3 text-[11px] focus:outline-none focus:border-uu-main transition-all min-h-[400px] font-mono leading-relaxed"
                placeholder="在這裡設定你的 Prompt 骨架..."
                ># Role: 部落格作家與內容策略師
                請根據我下方提供的【文章草稿表單】資訊，為我撰寫一篇結構完整、引人入勝且具備個人觀點的部落格文章。
                ## 📥 【文章草稿表單】（User Input） 1.
                **文章暫定標題或主題方向：** &#123;&#123;q1&#125;&#125; 2.
                **目標受眾（這篇文章寫給誰看）：** &#123;&#123;q2&#125;&#125; 3.
                **核心觀點與目的（讀完這篇文章，讀者能帶走什麼？）：**
                &#123;&#123;q3&#125;&#125; 4. **關鍵段落與大綱（列出 3-5
                個重點）：** &#123;&#123;q4&#125;&#125; 5.
                **個人獨特經驗與細節（必填，這是文章的靈魂）：**
                &#123;&#123;q5&#125;&#125; 6. **行文語氣與風格：**
                &#123;&#123;q6&#125;&#125; --- ## 📤 輸出要求 (Output
                Requirements) 請嚴格遵守以下規則撰寫文章： 1. **Markdown
                格式**：請使用標準 Markdown 語法排版（包含 H2 ##、H3 ###
                標題、粗體、條列式清單、引用區塊、表格等），確保文章層次分明、易於閱讀。
                2.
                **吸引人的開場**：第一段必須點出痛點或引起共鳴，直接破題，吸引讀者往下看。
                3. **無縫融入個人細節**：請將表單第 5
                點的「個人獨特經驗」自然地揉合進文章段落中，不要像是生硬的條列，要帶有「人味」。
                4. **流暢的轉折**：段落之間必須有邏輯連貫的過渡句。 5.
                **有力量的結尾**：總結核心觀點，並提供一個 Call to
                Action（例如：問讀者一個問題、鼓勵他們留言、或分享下一步計畫）。
                ### 【生成 .md 前綴】
                當我回答完上述問題後，請你「吸收」我的回答，並**直接產出一段完整的
                Markdown (.md) 程式碼區塊**。 請嚴格遵守以下輸出格式：
                ```markdown --- title:
                "【&#123;&#123;cat&#125;&#125;】幫我想一個吸睛的主題標題"
                description: "請根據文章內容生成約 50 字的溫暖 SEO 摘要"
                publishDate: &#123;&#123;date&#125;&#125; category:
                [&#123;&#123;cat&#125;&#125;] tags:
                [&#123;&#123;tags&#125;&#125;] heroImage:
                '/images/&#123;&#123;datePath&#125;&#125;/&#123;&#123;datePath&#125;&#125;-&#123;&#123;slug&#125;&#125;-01.jpg'
                --- ```</textarea
            >
            <p class="text-[9px] text-uu-main/40 mt-1">
                您可以使用 <code
                    class="bg-white px-1 py-0.5 rounded shadow-sm border border-uu-sub/10 opacity-80"
                    >&#123;&#123;變數&#125;&#125;</code
                > 來替換上方表單內容，例如：&#123;&#123;q1&#125;&#125;, &#123;&#123;cat&#125;&#125;,
                &#123;&#123;tags&#125;&#125;
            </p>
        </div>

        <div class="pt-6">
            <button
                id="generate-draft-btn"
                class="w-full py-4 bg-uu-main text-white rounded-2xl font-black tracking-widest uppercase hover:bg-uu-dark transition-all flex items-center justify-center gap-3"
            >
                <span class="material-symbols-outlined"
                    >temp_preferences_custom</span
                >
                <span>生成文章草稿 PROMPT</span>
            </button>
        </div>

        <div
            id="draft-result-container"
            class="hidden space-y-4 animate-fade-in pb-10"
        >
            <div class="flex items-center justify-between">
                <label
                    class="text-[10px] font-black text-uu-main/40 uppercase tracking-widest"
                    >生成的 AI PROMPT</label
                >
                <button
                    id="copy-prompt-btn"
                    class="flex items-center gap-2 px-3 py-1.5 bg-uu-main/10 text-uu-main rounded-lg text-[10px] font-black tracking-widest uppercase hover:bg-uu-main hover:text-white transition-all"
                >
                    <span class="material-symbols-outlined text-sm"
                        >content_copy</span
                    >
                    <span>複製內容</span>
                </button>
            </div>
            <textarea
                id="draft-result"
                readonly
                class="w-full bg-white border border-uu-sub/30 rounded-2xl p-6 text-xs font-mono leading-relaxed h-[400px] focus:outline-none shadow-sm"
            ></textarea>
        </div>
    </div>
</section>
<script>
    import { db } from "../../lib/firebase";
    import { doc, getDoc, setDoc, serverTimestamp } from "firebase/firestore";

    if (typeof window !== "undefined") {
        // --- Draft Tool Module ---
        const generateDraftBtn = document.getElementById("generate-draft-btn");
        const copyPromptBtn = document.getElementById("copy-prompt-btn");
        const draftResultContainer = document.getElementById(
            "draft-result-container"
        );
        const draftResultArea = document.getElementById(
            "draft-result"
        ) as HTMLTextAreaElement;
        const saveTemplateBtn = document.getElementById("save-template-btn");

        async function fetchPromptConfig() {
            const templateEl = document.getElementById(
                "draft-template"
            ) as HTMLTextAreaElement;
            if (!templateEl) return;

            try {
                const docRef = doc(db, "site_config", "prompt_settings");
                const docSnap = await getDoc(docRef);
                if (docSnap.exists()) {
                    const data = docSnap.data();
                    if (data.template_content) {
                        templateEl.value = data.template_content;
                        console.log(
                            "[System] Prompt template loaded from database."
                        );
                    }
                }
            } catch (err) {
                console.error("Error fetching prompt config:", err);
            }
        }

        saveTemplateBtn?.addEventListener("click", async () => {
            const templateEl = document.getElementById(
                "draft-template"
            ) as HTMLTextAreaElement;
            if (!templateEl) return;

            if (
                !(await (window as any).CustomModal.confirm({
                    title: "儲存預設模板",
                    message:
                        "確定要將目前的微調內容儲存為資料庫的『預設模板』嗎？儲存後重新整理頁面也會生效。",
                    confirmText: "儲存模板",
                    icon: "save_as",
                }))
            )
                return;

            const originalHtml = saveTemplateBtn.innerHTML;
            saveTemplateBtn.innerHTML = `<span class="material-symbols-outlined text-xs animate-spin">sync</span> 儲存中...`;
            saveTemplateBtn.setAttribute("disabled", "true");

            try {
                await setDoc(doc(db, "site_config", "prompt_settings"), {
                    template_content: templateEl.value,
                    updated_at: serverTimestamp(),
                });
                (window as any).showToast("模板已成功保存至雲端", "success");
            } catch (err) {
                (window as any).showToast("儲存失敗: " + err, "error");
            } finally {
                saveTemplateBtn.innerHTML = originalHtml;
                saveTemplateBtn.removeAttribute("disabled");
            }
        });

        function initDraftTool() {
            fetchPromptConfig();

            generateDraftBtn?.addEventListener("click", () => {
                const q1 =
                    (document.getElementById("draft-q1") as HTMLInputElement)
                        .value || "[未填寫]";
                const q2 =
                    (document.getElementById("draft-q2") as HTMLInputElement)
                        .value || "[未填寫]";
                const q3 =
                    (document.getElementById("draft-q3") as HTMLInputElement)
                        .value || "[未填寫]";
                const q4 =
                    (document.getElementById("draft-q4") as HTMLTextAreaElement)
                        .value || "[未填寫]";
                const q5 =
                    (document.getElementById("draft-q5") as HTMLTextAreaElement)
                        .value || "[未填寫]";
                const q6 =
                    (document.getElementById("draft-q6") as HTMLInputElement)
                        .value || "輕鬆幽默的個人隨筆";
                const slug =
                    (document.getElementById("draft-slug") as HTMLInputElement)
                        .value || "your-slug";
                const cat =
                    (document.getElementById("draft-cat") as HTMLInputElement)
                        .value || "";
                const tags =
                    (document.getElementById("draft-tags") as HTMLInputElement)
                        .value || "";

                const today = new Date().toISOString().split("T")[0];
                const datePath = today.substring(2, 4) + today.substring(5, 7); // YYMM

                // Handle Tags Logic (Dynamic Expansion if < 5)
                let tagsOutput = "我回答的標籤，無則你負責生成，至少 6 個";
                if (tags.trim()) {
                    const tagsArr = tags
                        .split(",")
                        .map((t) => t.trim())
                        .filter((t) => t);
                    if (tagsArr.length > 0 && tagsArr.length < 5) {
                        tagsOutput = `${tagsArr.join(
                            ", "
                        )}，請以此為基礎擴增到至少 6 個以上`;
                    } else if (tagsArr.length >= 5) {
                        tagsOutput = tagsArr.join(", ");
                    }
                }

                // Get template string
                const templateEl = document.getElementById(
                    "draft-template"
                ) as HTMLTextAreaElement;
                let prompt = templateEl ? templateEl.value : "";

                // Format q4 to handle line breaks properly if not empty
                const formattedQ4 =
                    q4 !== "[未填寫]"
                        ? q4
                              .split("\n")
                              .filter((l) => l.trim())
                              .map(
                                  (line) =>
                                      `   ${
                                          line.trim().startsWith("-")
                                              ? ""
                                              : "- "
                                      }${line}`
                              )
                              .join("\n")
                        : q4;

                // Replace variables placeholders with actual values
                prompt = prompt
                    .replace(/\{\{q1\}\}/g, q1)
                    .replace(/\{\{q2\}\}/g, q2)
                    .replace(/\{\{q3\}\}/g, q3)
                    .replace(/\{\{q4\}\}/g, formattedQ4)
                    .replace(/\{\{q5\}\}/g, q5)
                    .replace(/\{\{q6\}\}/g, q6)
                    .replace(/\{\{slug\}\}/g, slug)
                    .replace(
                        /\{\{cat\}\}/g,
                        cat || "我回答的分類，無則你負責生成"
                    )
                    .replace(/\{\{tags\}\}/g, tagsOutput)
                    .replace(/\{\{date\}\}/g, today)
                    .replace(/\{\{datePath\}\}/g, datePath);

                if (draftResultArea) draftResultArea.value = prompt;
                draftResultContainer?.classList.remove("hidden");
                draftResultContainer?.scrollIntoView({ behavior: "smooth" });
            });

            copyPromptBtn?.addEventListener("click", () => {
                if (draftResultArea) {
                    draftResultArea.select();
                    document.execCommand("copy");
                    const originalText = copyPromptBtn.innerHTML;
                    copyPromptBtn.innerHTML = `<span class="material-symbols-outlined text-sm">done</span> 已複製`;
                    setTimeout(() => {
                        copyPromptBtn.innerHTML = originalText;
                    }, 2000);
                }
            });
        }

        // Expose init function to window
        (window as any).initDraftTool = initDraftTool;
    }
</script>
