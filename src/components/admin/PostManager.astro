---
---

<div
    id="tab-manage"
    class="tab-content hidden animate-in fade-in slide-in-from-bottom-4 duration-500"
>
    <div class="flex items-center justify-between mb-8">
        <div>
            <h2 class="text-2xl font-black text-uu-dark tracking-tight">
                文章列表 <span
                    class="text-uu-main/20 ml-2 font-mono text-sm"
                    id="posts-count-info">Listing ...</span
                >
            </h2>
            <p
                class="text-xs text-uu-main/40 font-medium tracking-wide uppercase mt-1"
            >
                Manage all your markdown posts from GitHub
            </p>
        </div>
        <div class="flex items-center gap-3">
            <!-- Search/Filter Placeholder -->
            <div class="relative">
                <select id="manage-category-filter" class="hidden">
                    <option value="all">所有分類 (All)</option>
                </select>
            </div>

            <button
                id="refresh-posts-btn"
                class="w-12 h-12 flex items-center justify-center bg-white border border-uu-sub/30 rounded-2xl text-uu-main hover:bg-uu-main hover:text-white hover:border-uu-main transition-all active:scale-95 shadow-sm group"
            >
                <span
                    class="material-symbols-outlined text-xl group-hover:rotate-180 transition-transform duration-500"
                    >refresh</span
                >
            </button>
        </div>
    </div>

    <div
        class="bg-white rounded-3xl border border-uu-sub/20 shadow-xl shadow-uu-main/5 overflow-hidden"
    >
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="border-b border-uu-sub/10 bg-uu-base/10">
                        <th
                            class="px-6 py-4 text-[10px] font-black text-uu-main/40 uppercase tracking-widest"
                            >日期 (Date)</th
                        >
                        <th
                            class="px-6 py-4 text-[10px] font-black text-uu-main/40 uppercase tracking-widest"
                            >標題與檔名 (Title & Filename)</th
                        >
                        <th
                            class="px-6 py-4 text-[10px] font-black text-uu-main/40 uppercase tracking-widest text-center"
                            >分類 (Category)</th
                        >
                        <th
                            class="px-6 py-4 text-[10px] font-black text-uu-main/40 uppercase tracking-widest text-right"
                            >操作 (Action)</th
                        >
                    </tr>
                </thead>
                <tbody id="posts-table-body">
                    <!-- JS Injected -->
                </tbody>
            </table>
        </div>
        <!-- Pagination -->
        <div
            id="manage-pagination"
            class="px-6 py-4 border-t border-uu-sub/10 bg-uu-base/5 flex items-center justify-center gap-2"
        >
            <!-- JS Injected -->
        </div>
    </div>
</div>
<script>
    import { githubSync } from "../../lib/githubSync";

    if (typeof window !== "undefined") {
        const postsTableBody = document.getElementById("posts-table-body");
        const postsCountInfo = document.getElementById("posts-count-info");
        const paginationContainer =
            document.getElementById("manage-pagination");
        const categoryFilter = document.getElementById(
            "manage-category-filter"
        ) as HTMLSelectElement;
        const refreshPostsBtn = document.getElementById("refresh-posts-btn");
        const githubTokenInput = document.getElementById(
            "sys-github-token"
        ) as HTMLInputElement;

        let allPosts: any[] = [];
        let currentPage = 1;
        const itemsPerPage = 10;
        let currentFilter = "all";

        async function loadPosts() {
            if (!postsTableBody) return;

            postsTableBody.innerHTML = `
                <tr>
                    <td colspan="4" class="px-6 py-20 text-center">
                        <div class="flex flex-col items-center gap-4">
                            <span class="material-symbols-outlined animate-spin text-uu-main/20 text-4xl">sync</span>
                            <p class="text-uu-main/40 text-xs italic">正在與 GitHub 同步清單...</p>
                        </div>
                    </td>
                </tr>
            `;

            const token = githubTokenInput?.value.trim() || "";
            if (!token) {
                postsTableBody.innerHTML = `<tr><td colspan="4" class="px-6 py-20 text-center text-uu-main/40 text-xs italic">請先在全站設定中儲存 GitHub 權杖。</td></tr>`;
                return;
            }

            try {
                allPosts = await githubSync.listPosts({
                    token,
                    owner: "uu-memo",
                    repo: "uu-memo.github.io",
                });

                updateCategoryFilter();
                renderPosts();
            } catch (err) {
                console.error("Failed to load posts:", err);
                postsTableBody.innerHTML = `<tr><td colspan="4" class="px-6 py-20 text-center text-uu-main/40 text-xs italic">載入失敗，請檢查權杖權限。</td></tr>`;
            }
        }

        function updateCategoryFilter() {
            if (!categoryFilter) return;
            const categories = new Set(allPosts.map((p) => p.category));
            const currentVal = categoryFilter.value;
            categoryFilter.innerHTML =
                '<option value="all">所有分類 (All)</option>';
            categories.forEach((cat) => {
                const option = document.createElement("option");
                option.value = cat;
                option.textContent = cat;
                categoryFilter.appendChild(option);
            });
            categoryFilter.value = currentVal;

            if ((window as any).UUSelect)
                (window as any).UUSelect.refresh("manage-category-filter");
        }

        function renderPosts() {
            if (!postsTableBody || !postsCountInfo || !paginationContainer)
                return;

            const filtered =
                currentFilter === "all"
                    ? allPosts
                    : allPosts.filter((p) => p.category === currentFilter);

            const totalPages = Math.ceil(filtered.length / itemsPerPage);
            const start = (currentPage - 1) * itemsPerPage;
            const end = start + itemsPerPage;
            const paginated = filtered.slice(start, end);

            postsCountInfo.textContent = `Showing ${start + 1}-${Math.min(
                end,
                filtered.length
            )} of ${filtered.length} posts`;

            if (paginated.length === 0) {
                postsTableBody.innerHTML = `<tr><td colspan="4" class="px-6 py-20 text-center text-uu-main/40 text-xs italic">找不到相關文章。</td></tr>`;
            } else {
                postsTableBody.innerHTML = paginated
                    .map((post) => {
                        const statusBadges = `
                        <div class="flex items-center gap-1.5 mt-1.5">
                            ${
                                post.draft
                                    ? '<span class="px-2 py-0.5 rounded-md bg-uu-sub/20 text-uu-main/60 text-[8px] font-black uppercase border border-uu-sub/30">Draft</span>'
                                    : ""
                            }
                            ${
                                !post.isVisible
                                    ? '<span class="px-2 py-0.5 rounded-md bg-uu-dark/5 text-uu-dark/60 text-[8px] font-black uppercase border border-uu-dark/10 flex items-center gap-1"><span class="material-symbols-outlined text-[10px]">visibility_off</span>Hidden</span>'
                                    : ""
                            }
                        </div>
                    `;

                        return `
                    <tr class="hover:bg-uu-base/5 transition-colors group">
                        <td class="px-6 py-4">
                            <span class="text-[11px] font-mono text-uu-main/60">${
                                post.publishDate
                            }</span>
                        </td>
                        <td class="px-6 py-4">
                            <div class="flex flex-col">
                                <span class="text-sm font-bold text-uu-dark group-hover:text-uu-main transition-colors">${
                                    post.title
                                }</span>
                                <span class="text-[10px] text-uu-main/30 font-mono">${
                                    post.name
                                }</span>
                                ${statusBadges}
                            </div>
                        </td>
                        <td class="px-6 py-4 text-center">
                            <span class="inline-block px-2 py-1 rounded-md bg-uu-sub/10 text-uu-main/60 text-[9px] font-black uppercase tracking-wider whitespace-nowrap">${
                                post.category
                            }</span>
                        </td>
                        <td class="px-6 py-4 text-right">
                            <div class="flex items-center justify-end gap-2">
                                <button class="edit-post-btn p-2 rounded-lg hover:bg-uu-main hover:text-white text-uu-main/40 transition-all active:scale-95" data-path="${
                                    post.path
                                }" data-name="${post.name.replace(".md", "")}">
                                    <span class="material-symbols-outlined text-sm">edit_note</span>
                                </button>
                                <a href="https://uu-memo.github.io/posts/${post.name.replace(
                                    ".md",
                                    ""
                                )}" target="_blank" class="p-2 rounded-lg hover:bg-uu-sub/20 text-uu-main/40 transition-all">
                                    <span class="material-symbols-outlined text-sm">open_in_new</span>
                                </a>
                                <button class="delete-post-btn p-2 rounded-lg hover:bg-uu-dark hover:text-white text-uu-main/40 transition-all active:scale-95" data-path="${
                                    post.path
                                }" data-title="${post.title}">
                                    <span class="material-symbols-outlined text-sm">delete</span>
                                </button>
                            </div>
                        </td>
                    </tr>
                `;
                    })
                    .join("");

                postsTableBody
                    .querySelectorAll(".edit-post-btn")
                    .forEach((btn) => {
                        btn.addEventListener("click", () => {
                            const path = btn.getAttribute("data-path")!;
                            const slug = btn.getAttribute("data-name")!;
                            if (
                                (window as any).PostEditor &&
                                (window as any).PostEditor.loadPost
                            ) {
                                (window as any).PostEditor.loadPost(path, slug);
                            }
                        });
                    });

                postsTableBody
                    .querySelectorAll(".delete-post-btn")
                    .forEach((btn) => {
                        btn.addEventListener("click", () => {
                            const path = btn.getAttribute("data-path")!;
                            const title = btn.getAttribute("data-title")!;
                            deletePost(path, title);
                        });
                    });
            }

            paginationContainer.innerHTML = "";
            for (let i = 1; i <= totalPages; i++) {
                const btn = document.createElement("button");
                btn.className = `w-8 h-8 rounded-lg text-[10px] font-black transition-all ${
                    i === currentPage
                        ? "bg-uu-main text-white shadow-lg"
                        : "bg-uu-sub/10 text-uu-main/40 hover:bg-uu-sub/20"
                }`;
                btn.textContent = i.toString();
                btn.addEventListener("click", () => {
                    currentPage = i;
                    renderPosts();
                });
                paginationContainer.appendChild(btn);
            }
        }

        async function deletePost(path: string, title: string) {
            const token = githubTokenInput?.value.trim();
            if (!token) return;

            if (
                !(await (window as any).CustomModal.confirm({
                    title: "徹底刪除文章",
                    message: `確定要從 GitHub 徹底移除「${title}」嗎？此操作不可恢復，並將觸發網站重新建置。`,
                    confirmText: "執行刪除",
                    theme: "main",
                    icon: "delete_forever",
                }))
            )
                return;

            if ((window as any).showToast)
                (window as any).showToast("正在從 GitHub 刪除檔案...", "info");

            try {
                await githubSync.deleteFile(
                    {
                        token,
                        owner: "uu-memo",
                        repo: "uu-memo.github.io",
                        message: `Admin: Delete post "${title}"`,
                        branch: "main",
                    },
                    path
                );

                if ((window as any).showToast)
                    (window as any).showToast(
                        "文章已從儲存庫移除。",
                        "success"
                    );
                loadPosts(); // Refresh list
            } catch (err) {
                if ((window as any).showToast)
                    (window as any).showToast("刪除失敗: " + err, "error");
            }
        }

        const PostManager = {
            refresh: loadPosts,
            clear: () => {
                allPosts = [];
                if (postsTableBody) postsTableBody.innerHTML = "";
            },
        };

        (window as any).PostManager = PostManager;

        // --- Event Listeners ---
        refreshPostsBtn?.addEventListener("click", () => {
            currentPage = 1;
            loadPosts();
        });

        categoryFilter?.addEventListener("change", () => {
            currentFilter = categoryFilter.value;
            currentPage = 1;
            renderPosts();
        });

        const manageTabBtn = document.querySelector('[data-tab="manage"]');
        manageTabBtn?.addEventListener("click", () => {
            if (allPosts.length === 0) loadPosts();
        });
    }
</script>
