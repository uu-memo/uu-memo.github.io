---
---

<section
    id="tab-system"
    class="tab-content hidden w-full flex-1 flex flex-col p-10"
>
    <!-- Header -->
    <div
        class="flex items-center justify-between mb-8 pb-6 border-b border-uu-sub/20"
    >
        <div class="flex items-center gap-3.5">
            <div
                class="w-10 h-10 rounded-full bg-uu-sub/10 flex items-center justify-center text-uu-main"
            >
                <span class="material-symbols-outlined">payments</span>
            </div>
            <h3 class="font-bold text-xl text-uu-dark">全站設定</h3>
        </div>
        <div
            class="flex items-center gap-4 bg-uu-base/20 px-5 py-2.5 rounded-2xl border border-uu-sub/10"
        >
            <span
                class="text-[10px] font-black text-uu-main/40 uppercase tracking-widest"
                >贊助模組狀態</span
            >
            <label class="relative inline-flex items-center cursor-pointer">
                <input
                    type="checkbox"
                    id="sys-donate-enabled"
                    class="sr-only peer"
                    checked
                />
                <div
                    class="w-11 h-6 bg-uu-sub/20 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-uu-sub/30 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-uu-main"
                >
                </div>
            </label>
        </div>
    </div>

    <div class="space-y-10">
        <!-- Donation Config Section -->
        <div
            class="bg-white border border-uu-sub/20 rounded-2xl p-8 space-y-8 shadow-sm"
        >
            <div
                class="flex items-center gap-3 mb-2 pb-4 border-b border-uu-sub/10"
            >
                <div
                    class="w-8 h-8 rounded-lg bg-uu-main/5 flex items-center justify-center"
                >
                    <span class="material-symbols-outlined text-uu-main text-sm"
                        >settings_heart</span
                    >
                </div>
                <h4
                    class="text-xs font-black text-uu-dark uppercase tracking-widest"
                >
                    贊助詳情設定 (Donation Settings)
                </h4>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="space-y-3">
                    <label
                        class="text-[10px] font-black text-uu-main/40 uppercase tracking-widest block"
                        >Platform Title (平台名稱)</label
                    >
                    <input
                        type="text"
                        id="sys-donate-name"
                        class="w-full bg-uu-base/20 border border-uu-sub/20 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-uu-main focus:bg-white transition-all shadow-inner"
                        placeholder="例如：Buy Me a Coffee"
                        autocomplete="off"
                        data-lpignore="true"
                    />
                </div>
                <div class="space-y-3">
                    <label
                        class="text-[10px] font-black text-uu-main/40 uppercase tracking-widest block"
                        >Donation Link (贊助連結)</label
                    >
                    <input
                        type="url"
                        id="sys-donate-url"
                        class="w-full bg-uu-base/20 border border-uu-sub/20 rounded-xl px-4 py-3 text-sm focus:outline-none focus:border-uu-main focus:bg-white transition-all shadow-inner"
                        placeholder="https://..."
                        autocomplete="off"
                        data-lpignore="true"
                    />
                </div>
            </div>

            <div class="space-y-3">
                <label
                    class="text-[10px] font-black text-uu-main/40 uppercase tracking-widest block"
                    >Display Message (顯示內容)</label
                >
                <textarea
                    id="sys-donate-msg"
                    class="w-full bg-uu-base/10 border border-uu-sub/10 rounded-2xl p-8 text-sm leading-relaxed focus:outline-none focus:bg-white transition-all min-h-[160px] shadow-inner"
                    placeholder="輸入您想對贊助者說的話..."></textarea>
            </div>

            <div class="pt-2 flex justify-end">
                <button
                    id="sys-save-btn"
                    class="px-8 py-3.5 bg-uu-main text-white rounded-xl font-black text-[10px] tracking-[0.2em] uppercase hover:bg-uu-dark transition-all flex items-center gap-2 shadow-sm"
                >
                    <span class="material-symbols-outlined text-sm">save</span>
                    <span id="save-donation-text">儲存贊助設定</span>
                    <div
                        id="save-donation-loader"
                        class="hidden w-3 h-3 border-2 border-white/20 border-t-white rounded-full animate-spin"
                    >
                    </div>
                </button>
            </div>
        </div>

        <!-- GitHub Vault Config Section -->
        <div
            class="bg-uu-dark rounded-[2.5rem] p-10 space-y-8 shadow-2xl relative overflow-hidden group"
        >
            <!-- Decorative Background -->
            <div
                class="absolute top-0 right-0 w-64 h-64 bg-white/5 rounded-full -translate-y-1/2 translate-x-1/2 blur-3xl group-hover:bg-white/10 transition-colors"
            >
            </div>

            <div
                class="flex items-center gap-4 mb-2 pb-6 border-b border-white/10"
            >
                <div
                    class="w-12 h-12 rounded-2xl bg-white/10 flex items-center justify-center text-white"
                >
                    <span class="material-symbols-outlined text-2xl">key</span>
                </div>
                <div>
                    <h4
                        class="text-xs font-black text-white/40 uppercase tracking-[0.3em]"
                    >
                        GitHub Token Vault
                    </h4>
                    <p class="text-[11px] text-white/20 font-mono mt-1">
                        Securely manage your personal access tokens
                    </p>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                <div class="space-y-4">
                    <label
                        class="text-[10px] font-black text-white/40 uppercase tracking-widest block pl-1"
                        >Personal Access Token</label
                    >
                    <div class="relative">
                        <input
                            type="password"
                            id="sys-github-token"
                            class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-sm text-white focus:outline-none focus:border-white/30 focus:bg-white/10 transition-all font-mono"
                            placeholder="ghp_xxxxxxxxxxxx"
                            autocomplete="off"
                        />
                        <button
                            id="toggle-token-visibility"
                            class="absolute right-5 top-1/2 -translate-y-1/2 text-white/20 hover:text-white transition-colors"
                        >
                            <span class="material-symbols-outlined text-lg"
                                >visibility</span
                            >
                        </button>
                    </div>
                </div>
                <div class="space-y-4">
                    <label
                        class="text-[10px] font-black text-white/40 uppercase tracking-widest block pl-1"
                        >Token Note (Optional)</label
                    >
                    <input
                        type="text"
                        id="sys-github-token-note"
                        class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-4 text-sm text-white focus:outline-none focus:border-white/30 focus:bg-white/10 transition-all"
                        placeholder="例如：主站更新專用"
                        autocomplete="off"
                    />
                </div>
            </div>

            <div
                class="p-6 bg-white/5 rounded-2xl border border-white/10 flex items-start gap-4"
            >
                <span class="material-symbols-outlined text-white/40 text-sm"
                    >verified_user</span
                >
                <p
                    class="text-[10px] text-white/40 leading-relaxed font-medium"
                >
                    您的權杖僅會儲存在 Firebase
                    加密金庫中，用於代表您發布文章與上傳圖片至
                    GitHub。請確保權杖具備 <code
                        class="bg-white/10 px-1.5 py-0.5 rounded text-white/60"
                        >public_repo</code
                    > 或 <code
                        class="bg-white/10 px-1.5 py-0.5 rounded text-white/60"
                        >repo</code
                    > 權限。
                </p>
            </div>

            <div class="pt-4 flex justify-end">
                <button
                    id="save-github-token-btn"
                    class="px-10 py-4.5 bg-white text-uu-dark rounded-2xl font-black text-[11px] tracking-[0.2em] uppercase hover:bg-white/90 active:scale-95 transition-all flex items-center gap-3 shadow-xl"
                >
                    <span class="material-symbols-outlined text-lg"
                        >lock_open</span
                    >
                    <span id="save-token-btn-text">儲存 GitHub 權杖</span>
                    <div
                        id="save-token-loader"
                        class="hidden w-4 h-4 border-2 border-uu-dark/20 border-t-uu-dark rounded-full animate-spin"
                    >
                    </div>
                </button>
            </div>
        </div>
    </div>
</section>

<script>
    import { db } from "../../lib/firebase";
    import { doc, getDoc, setDoc, serverTimestamp } from "firebase/firestore";

    if (typeof window !== "undefined") {
        const sysDonateName = document.getElementById(
            "sys-donate-name"
        ) as HTMLInputElement;
        const sysDonateUrl = document.getElementById(
            "sys-donate-url"
        ) as HTMLInputElement;
        const sysDonateMsg = document.getElementById(
            "sys-donate-msg"
        ) as HTMLTextAreaElement;
        const sysDonateEnabled = document.getElementById(
            "sys-donate-enabled"
        ) as HTMLInputElement;
        const saveDonationBtn = document.getElementById("sys-save-btn");
        const saveDonationText = document.getElementById("save-donation-text");
        const saveDonationLoader = document.getElementById(
            "save-donation-loader"
        );

        const githubTokenInput = document.getElementById(
            "sys-github-token"
        ) as HTMLInputElement;
        const githubTokenNote = document.getElementById(
            "sys-github-token-note"
        ) as HTMLInputElement;
        const saveTokenBtn = document.getElementById("save-github-token-btn");
        const saveTokenText = document.getElementById("save-token-btn-text");
        const saveTokenLoader = document.getElementById("save-token-loader");
        const toggleTokenBtn = document.getElementById(
            "toggle-token-visibility"
        );

        // --- Fetch Configs ---
        async function fetchSystemConfig() {
            try {
                const docRef = doc(db, "site_config", "donation_settings");
                const docSnap = await getDoc(docRef);
                if (docSnap.exists()) {
                    const data = docSnap.data();
                    if (sysDonateName)
                        sysDonateName.value = data.platform_name || "";
                    if (sysDonateUrl) sysDonateUrl.value = data.link_url || "";
                    if (sysDonateMsg) sysDonateMsg.value = data.message || "";
                    if (sysDonateEnabled)
                        sysDonateEnabled.checked = data.enabled ?? true;
                }
            } catch (err) {
                console.error("Error fetching system config:", err);
            }
        }

        async function fetchGithubConfig() {
            try {
                const docRef = doc(db, "admin_vault", "credentials");
                const docSnap = await getDoc(docRef);
                if (docSnap.exists()) {
                    const data = docSnap.data();
                    if (githubTokenInput && data.github_token) {
                        githubTokenInput.value = data.github_token;
                    }
                    if (githubTokenNote && data.github_token_note) {
                        githubTokenNote.value = data.github_token_note;
                    }
                }
            } catch (err) {
                console.error(
                    "[System] Failed to fetch GitHub Token (Expected if not set):",
                    err
                );
            }
        }

        // --- Save Donation ---
        saveDonationBtn?.addEventListener("click", async () => {
            if (!saveDonationText || !saveDonationLoader) return;

            saveDonationText.textContent = "儲存中...";
            saveDonationLoader.classList.remove("hidden");
            saveDonationBtn.setAttribute("disabled", "true");

            try {
                await setDoc(doc(db, "site_config", "donation_settings"), {
                    platform_name: sysDonateName.value,
                    link_url: sysDonateUrl.value,
                    message: sysDonateMsg.value,
                    enabled: sysDonateEnabled.checked,
                });

                if ((window as any).showToast)
                    (window as any).showToast("贊助設定已成功儲存", "success");
                saveDonationText.textContent = "儲存成功";
                setTimeout(() => {
                    if (saveDonationText)
                        saveDonationText.textContent = "儲存全站設定";
                }, 2000);
            } catch (err) {
                if ((window as any).showToast)
                    (window as any).showToast("儲存失敗: " + err, "error");
            } finally {
                saveDonationLoader.classList.add("hidden");
                saveDonationBtn.removeAttribute("disabled");
            }
        });

        // --- Github Token Logic ---
        toggleTokenBtn?.addEventListener("click", () => {
            const type =
                githubTokenInput.getAttribute("type") === "password"
                    ? "text"
                    : "password";
            githubTokenInput.setAttribute("type", type);
            const icon = toggleTokenBtn.querySelector(
                ".material-symbols-outlined"
            );
            if (icon)
                icon.textContent =
                    type === "password" ? "visibility" : "visibility_off";
        });

        saveTokenBtn?.addEventListener("click", async () => {
            if (
                !saveTokenText ||
                !saveTokenLoader ||
                !githubTokenInput.value.trim()
            ) {
                if ((window as any).showToast)
                    (window as any).showToast("請輸入有效的權杖", "info");
                return;
            }

            saveTokenText.textContent = "正在加密金庫...";
            saveTokenLoader.classList.remove("hidden");
            saveTokenBtn.setAttribute("disabled", "true");

            try {
                await setDoc(doc(db, "admin_vault", "credentials"), {
                    github_token: githubTokenInput.value.trim(),
                    github_token_note: githubTokenNote?.value.trim() || "",
                    updated_at: serverTimestamp(),
                    owner: "jing180804@gmail.com",
                });

                if ((window as any).showToast)
                    (window as any).showToast(
                        "GitHub 權杖已安全儲存",
                        "success"
                    );
                saveTokenText.textContent = "TOKEN SECURED!";
                setTimeout(() => {
                    if (saveTokenText)
                        saveTokenText.textContent = "儲存 GitHub 權杖";
                }, 2000);
            } catch (err) {
                if ((window as any).showToast)
                    (window as any).showToast("儲存失敗: " + err, "error");
            } finally {
                saveTokenLoader.classList.add("hidden");
                saveTokenBtn.removeAttribute("disabled");
            }
        });

        // --- API Exposed ---
        (window as any).SystemSettings = {
            loadSettings: async () => {
                await fetchSystemConfig();
                await fetchGithubConfig();
            },
        };
    }
</script>
