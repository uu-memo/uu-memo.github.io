---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import PrimaryButton from "../../components/PrimaryButton.astro";

// New Modular Components
import Sidebar from "../../components/admin/Sidebar.astro";
import PostManager from "../../components/admin/PostManager.astro";
import PostEditor from "../../components/admin/PostEditor.astro";
import DraftTool from "../../components/admin/DraftTool.astro";
import CommentManager from "../../components/admin/CommentManager.astro";
import AuthorSettings from "../../components/admin/AuthorSettings.astro";
import SystemSettings from "../../components/admin/SystemSettings.astro";
import ModalGlobal from "../../components/admin/ModalGlobal.astro";
---

<Layout title="Admin Management | UU MEMO">
    <Header />

    <main
        class="max-w-6xl mx-auto px-6 py-12 md:py-20 min-h-[85vh] flex flex-col w-full self-stretch"
    >
        <!-- Auth Loading -->
        <div
            id="auth-loading"
            class="fixed inset-0 z-[60] bg-uu-base flex flex-col items-center justify-center space-y-4 transition-opacity duration-300"
        >
            <div
                class="w-12 h-12 border-4 border-uu-sub border-t-uu-main rounded-full animate-spin"
            >
            </div>
            <p
                class="text-uu-main/60 tracking-widest text-sm font-medium uppercase"
            >
                Authenticating...
            </p>
        </div>

        <!-- Admin Dashboard Container -->
        <div
            id="admin-dashboard"
            class="hidden opacity-0 transition-opacity duration-500 dashboard-layout w-full"
        >
            <Sidebar adminEmail="" />

            <!-- RIGHT COLUMN: Content -->
            <div
                class="dashboard-content bg-uu-light rounded-2xl border border-uu-sub/30 shadow-sm min-h-[700px] flex flex-col overflow-hidden"
            >
                <PostManager />
                <PostEditor />
                <DraftTool />
                <CommentManager />
                <AuthorSettings />
                <SystemSettings />
            </div>
        </div>

        <ModalGlobal />
    </main>
</Layout>

<script>
    import { auth, db } from "../../lib/firebase";
    import { onAuthStateChanged } from "firebase/auth";
    import { doc, getDoc } from "firebase/firestore";

    const GAS_URL = import.meta.env.PUBLIC_GAS_URL;
    (window as any).GAS_URL = GAS_URL;

    /**
     * UUSelect - 頂級自定義選擇器組件邏輯
     * 負責將原生的 select 轉換為具備圖標與高級動畫的 UI
     */
    if (typeof window !== "undefined") {
        const UUSelect = {
            instances: new Map<string, any>(),
            init(selectId: string, options: any = {}) {
                const nativeSelect = document.getElementById(
                    selectId
                ) as HTMLSelectElement;
                if (!nativeSelect) return;

                const container = nativeSelect.closest(
                    ".uu-select-container"
                ) as HTMLElement;
                if (!container) return;

                // 建立或獲取 Trigger
                let trigger = container.querySelector(
                    ".uu-select-trigger"
                ) as HTMLElement;
                if (!trigger) {
                    trigger = document.createElement("div");
                    trigger.className = "uu-select-trigger";
                    trigger.innerHTML = `<div class="selected-content"><span class="material-symbols-outlined trigger-icon"></span><span class="selected-text"></span></div><span class="material-symbols-outlined arrow-icon">expand_more</span>`;
                    container.appendChild(trigger);
                }

                // 建立或獲取 Dropdown
                let dropdown = container.querySelector(
                    ".uu-select-dropdown"
                ) as HTMLElement;
                if (!dropdown) {
                    dropdown = document.createElement("div");
                    dropdown.className = "uu-select-dropdown";
                    container.appendChild(dropdown);
                }

                const instance = {
                    nativeSelect,
                    container,
                    trigger,
                    dropdown,
                    options,
                };
                this.instances.set(selectId, instance);
                this.refresh(selectId);

                trigger.onclick = (e) => {
                    e.stopPropagation();
                    this.toggle(selectId);
                };

                // 全局點擊關閉
                if (!(window as any)._uuSelectGlobalHandled) {
                    document.addEventListener("click", (e) => {
                        const target = e.target as HTMLElement;
                        if (target && !target.closest(".uu-select-container"))
                            this.closeAll();
                    });
                    (window as any)._uuSelectGlobalHandled = true;
                }
            },
            refresh(selectId: string) {
                const instance = this.instances.get(selectId);
                if (!instance) return;
                const { nativeSelect, trigger, dropdown, options } = instance;
                const selectedOption = nativeSelect.options[
                    nativeSelect.selectedIndex
                ] as HTMLOptionElement;
                const selectedText = trigger.querySelector(".selected-text");
                const triggerIcon = trigger.querySelector(
                    ".trigger-icon"
                ) as HTMLElement;

                if (selectedText)
                    selectedText.textContent = selectedOption
                        ? selectedOption.textContent
                        : "請選擇...";

                if (triggerIcon && selectedOption) {
                    const icon = options.icons
                        ? options.icons[selectedOption.value]
                        : options.defaultIcon || "label";
                    triggerIcon.textContent = icon;
                    triggerIcon.style.display = icon ? "block" : "none";
                }

                dropdown.innerHTML = "";
                Array.from(nativeSelect.options).forEach((opt: any, index) => {
                    const item = document.createElement("div");
                    item.className = `uu-select-option ${
                        index === nativeSelect.selectedIndex ? "selected" : ""
                    }`;
                    const icon = options.icons
                        ? options.icons[opt.value]
                        : options.defaultIcon || "label";
                    item.innerHTML = `<span class="material-symbols-outlined option-icon">${icon}</span><span>${opt.textContent}</span>`;
                    item.onclick = (e) => {
                        e.stopPropagation();
                        nativeSelect.value = opt.value;
                        nativeSelect.dispatchEvent(new Event("change"));
                        this.refresh(selectId);
                        this.closeAll();
                    };
                    dropdown.appendChild(item);
                });
            },
            toggle(selectId: string) {
                const instance = this.instances.get(selectId);
                if (!instance) return;
                const isOpen = instance.dropdown.classList.contains("open");
                this.closeAll();
                if (!isOpen) {
                    instance.dropdown.classList.add("open");
                    instance.trigger.classList.add("active");
                }
            },
            closeAll() {
                this.instances.forEach((i) => {
                    i.dropdown.classList.remove("open");
                    i.trigger.classList.remove("active");
                });
            },
        };
        (window as any).UUSelect = UUSelect;
    }

    // --- Authentication & Initialization ---

    onAuthStateChanged(auth, async (user) => {
        const loading = document.getElementById("auth-loading");
        const dashboard = document.getElementById("admin-dashboard");
        const emailSpan = document.getElementById("admin-email");

        if (!user) {
            window.location.replace("/login");
            return;
        }

        console.log("[Auth] User detected:", user.email);

        try {
            // Permission Trap: 只有管理員可以加載此頁面
            const adminRef = doc(db, "admin_vault", "credentials");
            await getDoc(adminRef);

            console.log("[System] Admin Verified.");
            if (emailSpan) emailSpan.textContent = user.email;

            // 初始化 Tabs
            initTabs();

            // 延遲初始化各組件邏輯，確保 DOM 已就緒
            setTimeout(() => {
                if ((window as any).SystemSettings)
                    (window as any).SystemSettings.loadSettings();
                if ((window as any).AuthorSettings)
                    (window as any).AuthorSettings.loadSettings();
                if ((window as any).initCommentsModule)
                    (window as any).initCommentsModule();
                if ((window as any).initDraftTool)
                    (window as any).initDraftTool();
                if ((window as any).PostManager)
                    (window as any).PostManager.refresh();
            }, 100);

            // 顯示儀表板
            loading?.classList.add("opacity-0");
            setTimeout(() => {
                loading?.classList.add("hidden");
                dashboard?.classList.remove("hidden");
                dashboard?.classList.add("opacity-100");
            }, 300);
        } catch (err) {
            console.error("[Auth] Access Denied:", err);
            window.location.replace("/user");
        }
    });

    // --- Tab Switching Logic ---
    function initTabs() {
        const tabBtns = document.querySelectorAll(".tab-btn");
        const tabContents = document.querySelectorAll(".tab-content");

        tabBtns.forEach((btn) => {
            btn.addEventListener("click", () => {
                const tab = btn.getAttribute("data-tab");

                // 更新按鈕狀態
                tabBtns.forEach((b) => {
                    b.classList.remove(
                        "active",
                        "bg-uu-main",
                        "text-white",
                        "shadow-sm"
                    );
                    b.classList.add(
                        "text-uu-main/60",
                        "hover:bg-uu-sub/10",
                        "hover:text-uu-main"
                    );
                });
                btn.classList.add(
                    "active",
                    "bg-uu-main",
                    "text-white",
                    "shadow-sm"
                );
                btn.classList.remove(
                    "text-uu-main/60",
                    "hover:bg-uu-sub/10",
                    "hover:text-uu-main"
                );

                // 切換內容顯示
                tabContents.forEach((content) => {
                    content.classList.add("hidden");
                    if (content.id === `tab-${tab}`)
                        content.classList.remove("hidden");
                });

                // 切換至管理分頁時自動刷新列表
                if (tab === "manage" && (window as any).PostManager) {
                    (window as any).PostManager.refresh();
                }
            });
        });
    }

    document.getElementById("logout-btn")?.addEventListener("click", () => {
        auth.signOut();
        window.location.reload();
    });
</script>

<style is:global>
    /* UUSelect Global Styles */
    .uu-select-container {
        position: relative;
        width: 100%;
    }
    .uu-select-trigger {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
        padding: 0.75rem 1rem;
        background: rgba(245, 240, 231, 0.4);
        border: 1px solid rgba(109, 73, 47, 0.15);
        border-radius: 0.75rem;
        font-size: 0.875rem;
        color: #4a301e;
        cursor: pointer;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        backdrop-filter: blur(10px);
    }
    .uu-select-trigger:hover {
        border-color: rgba(109, 73, 47, 0.4);
        background: white;
    }
    .uu-select-trigger.active {
        border-color: #6d492f;
        background: white;
        box-shadow: 0 0 0 4px rgba(109, 73, 47, 0.08);
    }
    .uu-select-trigger .selected-content {
        display: flex;
        align-items: center;
        gap: 0.625rem;
    }
    .uu-select-trigger .arrow-icon {
        font-size: 1.125rem;
        transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        color: rgba(109, 73, 47, 0.25);
    }
    .uu-select-trigger.active .arrow-icon {
        transform: rotate(180deg);
        color: #6d492f;
    }
    .uu-select-dropdown {
        position: absolute;
        top: calc(100% + 0.5rem);
        left: 0;
        right: 0;
        background: rgba(255, 255, 255, 0.98);
        backdrop-filter: blur(20px);
        border: 1px solid rgba(109, 73, 47, 0.12);
        border-radius: 1rem;
        box-shadow: 0 25px 50px -12px rgba(109, 73, 47, 0.2);
        z-index: 2000;
        opacity: 0;
        visibility: hidden;
        transform: translateY(-12px) scale(0.96);
        transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
        padding: 0.625rem;
    }
    .uu-select-dropdown.open {
        opacity: 1;
        visibility: visible;
        transform: translateY(0) scale(1);
    }
    .uu-select-option {
        padding: 0.75rem 1rem;
        font-size: 0.8125rem;
        color: #6d492f;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        border-radius: 0.75rem;
        transition: all 0.2s;
    }
    .uu-select-option:hover {
        background: rgba(109, 73, 47, 0.04);
        transform: translateX(4px);
    }
    .uu-select-option.selected {
        background: #6d492f;
        color: white;
    }
</style>

<style>
    .dashboard-layout {
        display: grid;
        grid-template-columns: 288px minmax(0, 1fr);
        gap: 2.5rem;
        width: 100%;
    }
    .dashboard-sidebar {
        width: 288px;
        position: sticky;
        top: 6rem;
    }
    .dashboard-content {
        min-width: 0;
        width: 100%;
    }
    @media (max-width: 767px) {
        .dashboard-layout {
            display: flex;
            flex-direction: column;
        }
        .dashboard-sidebar {
            width: 100%;
            position: static;
        }
    }
</style>
