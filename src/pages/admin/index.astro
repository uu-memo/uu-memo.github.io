            return;
        }

        if (!confirm("確定要將文章與圖片同步至 GitHub 嗎？")) return;

        (window as any).showToast("正在建立同步請求...", 'info');

        const btnText = finalPushBtn.querySelector('span:not(.material-symbols-outlined)');
        const btnIcon = finalPushBtn.querySelector('.material-symbols-outlined');
        const originalText = btnText?.textContent || "";
        
        if (btnText) btnText.textContent = "SYNCING...";
        finalPushBtn.setAttribute("disabled", "true");

        try {
            const files = [];
            
            // 1. 準備 Markdown 文章
            const fileName = `${slug}.md`;
            const filePath = `src/content/posts/${fileName}`;
            files.push({
                path: filePath,
                content: btoa(unescape(encodeURIComponent(content)))
            });

            // 2. 準備圖片
            const datePath = new Date().toISOString().split('T')[0].substring(2, 4) + new Date().toISOString().split('T')[0].substring(5, 7);
            for (const img of processedImages) {
                const imgInput = document.querySelector(`.img-filename-input[data-id="${img.id}"]`) as HTMLInputElement;
                let finalName = imgInput?.value.trim() || img.id;
                if (!finalName.includes('.')) finalName += ".jpg";
                
                const imgPath = `public/images/${datePath}/${finalName}`;
                files.push({
                    path: imgPath,
                    content: img.url.split(',')[1]
                });
            }

            // 3. 發起批次同步請求 (單次 Commit)
            console.log("[Sync] Batch uploading files:", files.map(f => f.path));
            
            const syncResponse = await fetch(GAS_URL, {
                method: "POST",
                mode: "no-cors",
                body: JSON.stringify({
                    action: "batch_upload",
                    files: files,
                    message: `Admin: Sync "${slug}" (${files.length} files)`,
                    branch: "main"
                })
            });

            (window as any).showToast(`成功！已將 ${files.length} 個檔案統整為一次提交同步。`, 'success', 5000);
        } catch (err) {
            console.error("[Sync] Error:", err);
            (window as any).showToast("同步失敗，請檢查連線或 GAS 設定。", 'error');
        } finally {
            if (btnText) btnText.textContent = originalText;
            finalPushBtn.removeAttribute("disabled");
        }
    });

    // --- Cleanup Build Logic ---
    const cleanupBtn = document.getElementById("cleanup-build-btn");
    cleanupBtn?.addEventListener("click", async () => {
        if (!confirm("確定要從 GitHub 刪除 src/content/posts/test.md 嗎？這通常用於修復建置失敗。")) return;
        
        const originalContent = cleanupBtn.innerHTML;
        cleanupBtn.innerHTML = `<span class="material-symbols-outlined text-sm animate-spin">sync</span> 清理中...`;
        cleanupBtn.setAttribute("disabled", "true");

        try {
            await fetch(GAS_URL, {
                method: "POST",
                mode: "no-cors",
                body: JSON.stringify({
                    action: "delete_file",
                    path: "src/content/posts/test.md",
                    message: "Admin: Emergency cleanup of corrupted test.md",
                    branch: "main"
                })
            });
            (window as any).showToast("清理請求已送出！建置應會在幾分鐘後恢復正常。", 'success');
        } catch (err) {
            (window as any).showToast("清理失敗", 'error');
        } finally {
            cleanupBtn.innerHTML = originalContent;
            cleanupBtn.removeAttribute("disabled");
        }
    });

    // --- Seeding Logic ---
    const seedBtn = document.getElementById("seed-comments-btn");
    seedBtn?.addEventListener("click", async () => {
        if (!confirm("Add 3 test comments to Firestore?")) return;

        const testData = [
            {
                author_name: "小林",
                author_email: "lin@example.com",
                content:
                    "這篇文章寫得很有溫度，圖片的色調也配得很安靜。期待更多的分享！",
                post_slug: "2024-spring-trip",
                is_hidden: false,
                is_deleted: false,
                is_read: false,
                created_at: serverTimestamp(),
            },
            {
                author_name: "Art Explorer",
                author_email: "art@travel.io",
                content:
                    "關於膠卷攝影的那一段很有同感，那種等待沖洗的不確定感才是最迷人的地方。",
                post_slug: "film-photography-essence",
                is_hidden: true,
                is_deleted: false,
                is_read: false,
                created_at: serverTimestamp(),
            },
            {
                author_name: "匿名訪客",
                author_email: "",
                content: "請問這張照片是在哪裡拍的？構圖好美！",
                post_slug: "kyoto-morning-walk",
                is_hidden: false,
                is_deleted: false,
                is_read: true,
                created_at: serverTimestamp(),
            },
        ];

        try {
            for (const item of testData) {
                await addDoc(collection(db, "comments"), item);
            }
            alert("Test data seeded successfully!");
        } catch (e) {
            alert("Seeding failed: " + e);
        }
    });

    // --- Logic for Login Button ---
    adminLoginBtn?.addEventListener("click", async () => {
        try {
            const provider = new GoogleAuthProvider();
            await signInWithPopup(auth, provider);
        } catch (err: any) {
            alert("Login Failed: " + err.message);
        }
    });

    // --- Authentication & Initialization Execution ---
    onAuthStateChanged(auth, async (user) => {
        if (!user) {
            // No User -> Show Login UI
            loading?.classList.add("opacity-0");
            setTimeout(() => {
                loading?.classList.add("hidden");
                loginUI?.classList.remove("hidden");
                dashboard?.classList.add("hidden");
            }, 300);
            return;
        }

        // We have a user, now verify permission (Admin Trap)
        console.log("[Auth] User detected:", user.email);
        
        try {
            const credentialRef = doc(db, "admin_vault", "credentials");
            await getDoc(credentialRef); // Permission trap
            
            // Access Granted
            console.log("[System] Admin Verified.");
            // 專案名稱校驗
            const isUUMemo = window.location.hostname.includes('uu-memo') || window.location.hostname === 'localhost';
            console.log(`[System] Project Context Check: ${isUUMemo ? '✅ uu-memo' : '⚠️ Unknown Project'}`);
            if (!isUUMemo) {
                console.warn("[System] Warning: Running on a domain not associated with uu-memo.");
            }
            if (emailSpan) emailSpan.textContent = user.email;

            // Fetch Data
            fetchSystemConfig();
            fetchAuthorConfig();
            fetchPromptConfig();
            initCommentsModule();

            // Transition UI
            loading?.classList.add("opacity-0");
            loginUI?.classList.add("hidden");
            setTimeout(() => {
                loading?.classList.add("hidden");
                dashboard?.classList.remove("hidden");
                dashboard?.classList.add("opacity-100");
            }, 300);

        } catch (err: any) {
            // Access Denied (Logged in but no permission)
            console.error("[Auth] Access Denied for", user.email, ":", err.code);
            
            if (deniedEmail) deniedEmail.textContent = user.email || "Unknown Account";
            unauthorizedMsg?.classList.remove("hidden");
            
            loading?.classList.add("opacity-0");
            setTimeout(() => {
                loading?.classList.add("hidden");
                loginUI?.classList.remove("hidden");
            }, 300);
        }
    });

    document.getElementById("logout-btn")?.addEventListener("click", () => {
        auth.signOut();
        window.location.reload();
    });


    // --- Post Management Tab Logic ---
    const toggleListBtnMain = document.getElementById('toggle-list-btn-main');
    const postListContainerMain = document.getElementById('post-list-container-main');
    const listPlaceholderMain = document.getElementById('list-placeholder-main');

    async function fetchPostList() {
        if (!postListContainerMain || !listPlaceholderMain) return;
        
        listPlaceholderMain.classList.add('hidden');
        postListContainerMain.classList.remove('hidden');
        postListContainerMain.innerHTML = '<div class="text-center py-12 text-uu-main/40 italic flex flex-col items-center gap-2"><span class="material-symbols-outlined animate-spin text-xl">sync</span><span class="text-[10px] font-bold uppercase tracking-widest">正在從 GitHub 同步清單...</span></div>';

        try {
            const payload = {
                action: 'list_posts',
                token: PUBLIC_GAS_SECRET // 使用更新後的 token 欄位名稱
            };
            console.log("[Network] Fetching Post List from GAS...", payload);

            const response = await fetch(PUBLIC_GAS_URL, {
                method: 'POST',
                body: JSON.stringify(payload)
            });

            const result = await response.json();
            console.log("[Network] Received Result:", result);
            const isSuccess = result.success || result.status === 'success';
            
            if (isSuccess) {
                const files = result.files || result.posts || [];
                if (files.length === 0) {
                    postListContainerMain.innerHTML = '<div class="text-center py-12 text-uu-main/40 italic">查無文章檔案</div>';
                    return;
                }

                // Sort: newest first
                const sortedFiles = result.files.sort((a: any, b: any) => b.name.localeCompare(a.name));

                postListContainerMain.innerHTML = `
                    <div class="grid grid-cols-1 gap-3">
                        ${sortedFiles.map((file: any) => `
                            <div class="group flex items-center justify-between p-5 bg-uu-base/5 rounded-[2rem] border border-uu-sub/20 hover:border-uu-main/40 transition-all hover:bg-white hover:shadow-xl hover:shadow-uu-main/5">
                                <div class="flex items-center gap-5">
                                    <div class="w-12 h-12 rounded-2xl bg-uu-main/5 flex items-center justify-center text-uu-main group-hover:bg-uu-main group-hover:text-white transition-all duration-500">
                                        <span class="material-symbols-outlined text-xl">article</span>
                                    </div>
                                    <div class="min-w-0">
                                        <div class="text-sm font-bold text-uu-dark truncate max-w-[200px] md:max-w-md">${file.name}</div>
                                        <div class="flex items-center gap-3 mt-1">
                                            <span class="text-[9px] font-black text-uu-main/40 uppercase tracking-widest leading-none">${(file.size / 1024).toFixed(1)} KB</span>
                                            <span class="w-1 h-1 rounded-full bg-uu-sub/40"></span>
                                            <span class="text-[9px] font-black text-uu-main/40 uppercase tracking-widest leading-none">${file.path.split('/').slice(-2, -1)}</span>
                                        </div>
                                    </div>
                                </div>
                                <button class="load-post-btn-main flex items-center gap-2 px-6 py-3 bg-uu-sub/10 text-uu-main hover:bg-uu-main hover:text-white rounded-2xl transition-all font-black text-[10px] tracking-widest uppercase shadow-sm active:scale-95" data-path="${file.path}">
                                    <span class="material-symbols-outlined text-sm">edit_square</span>編輯文章
                                </button>
                            </div>
                        `).join('')}
                    </div>
                `;

                // Bind Load Buttons
                document.querySelectorAll('.load-post-btn-main').forEach(btn => {
                    btn.addEventListener('click', async (e) => {
                        const path = (e.currentTarget as HTMLElement).dataset.path;
                        if (path) await loadPostContent(path);
                    });
                });
            } else {
                postListContainerMain.innerHTML = `<div class="text-uu-main/60 text-[10px] py-12 text-center font-bold uppercase tracking-tighter">載入失敗: ${result.message || '未知錯誤'}</div>`;
            }
        } catch (err) {
            console.error(err);
            (window as any).showToast("網路請求發生錯誤，請檢查網路狀態", 'error');
            postListContainerMain.innerHTML = `<div class="text-uu-main/60 text-[10px] py-12 text-center font-bold uppercase tracking-tighter italic">載入清單時發生意外錯誤</div>`;
        }
    }

    async function loadPostContent(path: string) {
        const editorTextarea = document.getElementById('md-content') as HTMLTextAreaElement;
        const slugInput = document.getElementById('post-slug') as HTMLInputElement;
        
        if (!editorTextarea || !slugInput) return;

        // Show fetching status
        const originalValue = editorTextarea.value;
        editorTextarea.value = "--- FETCHING FROM GITHUB ---";
        
        try {
            const response = await fetch(PUBLIC_GAS_URL, {
                method: 'POST',
                body: JSON.stringify({
                    action: 'get_content',
                    path: path,
                    secret: PUBLIC_GAS_SECRET
                })
            });

            const result = await response.json();
            
            if (result.success) {
                // Decode UTF-8 correctly
                const binary = atob(result.content);
                const bytes = new Uint8Array(binary.length);
                for (let i = 0; i < binary.length; i++) bytes[i] = binary.charCodeAt(i);
                const decodedContent = new TextDecoder().decode(bytes);
                
                editorTextarea.value = decodedContent;
                
                const fileName = path.split('/').pop() || '';
                slugInput.value = fileName.replace('.md', '');
                
                // Switch to Editor Tab via click
                const editorBtn = document.querySelector('.tab-btn[data-tab="editor"]') as HTMLElement;
                if (editorBtn) editorBtn.click();
                
                window.scrollTo({ top: 0, behavior: 'smooth' });
                // @ts-ignore
                if (window.updatePreview) window.updatePreview();
            } else {
                (window as any).showToast('載入失敗: ' + result.message, 'error');
                editorTextarea.value = originalValue;
            }
        } catch (err) {
            console.error(err);
            (window as any).showToast('網路請求錯誤', 'error');
            editorTextarea.value = originalValue;
        }
    }




    toggleListBtnMain?.addEventListener('click', fetchPostList);
    }
    // --- Draft Tool Logic ---
    const initDraftTool = () => {
        const generateDraftBtn = document.getElementById("generate-draft-btn");
        const copyPromptBtn = document.getElementById("copy-prompt-btn");
        const draftResultContainer = document.getElementById("draft-result-container");
        const draftResultArea = document.getElementById("draft-result") as HTMLTextAreaElement;

        generateDraftBtn?.addEventListener("click", () => {
            const q1 = (document.getElementById("draft-q1") as HTMLInputElement).value || "[未填寫]";
            const q2 = (document.getElementById("draft-q2") as HTMLInputElement).value || "[未填寫]";
            const q3 = (document.getElementById("draft-q3") as HTMLInputElement).value || "[未填寫]";
            const q4 = (document.getElementById("draft-q4") as HTMLTextAreaElement).value || "[未填寫]";
            const q5 = (document.getElementById("draft-q5") as HTMLTextAreaElement).value || "[未填寫]";
            const q6 = (document.getElementById("draft-q6") as HTMLInputElement).value || "輕鬆幽默的個人隨筆";
            const q7 = (document.getElementById("draft-q7") as HTMLTextAreaElement).value || "[未填寫]";
            const slug = (document.getElementById("draft-slug") as HTMLInputElement).value || "your-slug";
            const cat = (document.getElementById("draft-cat") as HTMLInputElement).value || "";
            const tags = (document.getElementById("draft-tags") as HTMLInputElement).value || "";

            const today = new Date().toISOString().split('T')[0];
            const datePath = today.substring(2, 4) + today.substring(5, 7); // YYMM
            
            // Handle Tags Logic (Dynamic Expansion if < 5)
            let tagsOutput = "我回答的標籤，無則你負責生成，至少 6 個";
            if (tags.trim()) {
                const tagsArr = tags.split(',').map(t => t.trim()).filter(t => t);
                if (tagsArr.length > 0 && tagsArr.length < 5) {
                    tagsOutput = `${tagsArr.join(', ')}，請以此為基礎擴增到至少 6 個以上`;
                } else if (tagsArr.length >= 5) {
                    tagsOutput = tagsArr.join(', ');
                }
            }

            // Get template string
            const templateEl = document.getElementById("draft-template") as HTMLTextAreaElement;
            let prompt = templateEl ? templateEl.value : "";
            
            // Format q4 to handle line breaks properly if not empty
            const formattedQ4 = q4 !== "[未填寫]" 
                ? q4.split('\n').filter(l => l.trim()).map(line => `   ${line.trim().startsWith('-') ? '' : '- '}${line}`).join('\n')
                : q4;

            // Replace variables placeholders with actual values
            prompt = prompt.replace(/\{\{q1\}\}/g, q1)
                           .replace(/\{\{q2\}\}/g, q2)
                           .replace(/\{\{q3\}\}/g, q3)
                           .replace(/\{\{q4\}\}/g, formattedQ4)
                           .replace(/\{\{q5\}\}/g, q5)
                           .replace(/\{\{q6\}\}/g, q6)
                           .replace(/\{\{q7\}\}/g, q7)
                           .replace(/\{\{slug\}\}/g, slug)
                           .replace(/\{\{cat\}\}/g, cat || '我回答的分類，無則你負責生成')
                           .replace(/\{\{tags\}\}/g, tagsOutput)
                           .replace(/\{\{date\}\}/g, today)
                           .replace(/\{\{datePath\}\}/g, datePath);

            if (draftResultArea) draftResultArea.value = prompt;
            draftResultContainer?.classList.remove("hidden");
            draftResultContainer?.scrollIntoView({ behavior: 'smooth' });
        });

        copyPromptBtn?.addEventListener("click", () => {
            if (draftResultArea) {
                draftResultArea.select();
                document.execCommand("copy");
                const originalText = copyPromptBtn.innerHTML;
                copyPromptBtn.innerHTML = `<span class="material-symbols-outlined text-sm">done</span> 已複製`;
                setTimeout(() => {
                    copyPromptBtn.innerHTML = originalText;
                }, 2000);
            }
        });
    };

    if (typeof window !== 'undefined') {
        initDraftTool();
    }
</script>

