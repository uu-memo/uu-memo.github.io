                        <div id="list-placeholder-main" class="flex-1 flex flex-col items-center justify-center border-2 border-dashed border-uu-sub/20 rounded-2xl py-20 bg-uu-base/5">
                            <span class="material-symbols-outlined text-4xl text-uu-main/10 mb-4">search</span>
                            <p class="text-sm text-uu-main/30 font-medium">點擊上方按鈕載入文章清單</p>
                            <p class="text-[10px] text-uu-main/20 mt-1 uppercase tracking-widest">Only .md files from src/content/posts will be shown</p>
                        </div>
