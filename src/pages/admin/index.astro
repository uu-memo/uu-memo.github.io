    (window as any).copyImageCode = (id: string) => {
        const input = document.querySelector(`.img-filename-input[data-id="${id}"]`) as HTMLInputElement;
        if (!input) return;

        let filename = input.value.trim();
        if (!filename) {
            (window as any).showToast("請先設定圖檔名稱", 'info');
            return;
        }
        if (!filename.includes('.')) filename += ".jpg";

        const now = new Date();
        const yy = now.getFullYear().toString().substring(2);
        const mm = (now.getMonth() + 1).toString().padStart(2, '0');
        const datePath = `${yy}${mm}`;
        
        const markdownCode = `![圖片](/images/${datePath}/${filename})`;
        
        navigator.clipboard.writeText(markdownCode).then(() => {
            (window as any).showToast("Markdown 代碼已複製！", 'success');
        }).catch(err => {
            console.error("Copy failed", err);
            (window as any).showToast("複製失敗", 'error');
        });
    };

