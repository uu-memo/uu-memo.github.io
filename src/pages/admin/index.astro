    // --- Featured Post Sync Logic ---
    const featuredCheckbox = document.getElementById("featured-checkbox") as HTMLInputElement;

    function updateFeaturedFromText() {
        if (!mdEditor || !featuredCheckbox) return;
        const content = mdEditor.value;
        const tagsMatch = content.match(/tags:\s*\[(.*?)\]/);
        if (tagsMatch) {
            const tagsStr = tagsMatch[1];
            const isFeatured = tagsStr.includes('"精選"') || tagsStr.includes("'精選'") || tagsStr.includes("精選");
            featuredCheckbox.checked = isFeatured;
        } else {
            featuredCheckbox.checked = false;
        }
    }

    function updateTextFromFeatured() {
        if (!mdEditor || !featuredCheckbox) return;
        let content = mdEditor.value;
        const isChecked = featuredCheckbox.checked;
        
        const tagsRegex = /tags:\s*\[(.*?)\]/;
        const match = content.match(tagsRegex);

        if (match) {
            let tagsStr = match[1].trim();
            let tagsArr = tagsStr ? tagsStr.split(',').map(t => t.trim().replace(/^['"]|['"]$/g, '')) : [];
            
            const index = tagsArr.indexOf("精選");
            
            if (isChecked && index === -1) {
                tagsArr.push("精選");
            } else if (!isChecked && index !== -1) {
                tagsArr.splice(index, 1);
            } else {
                return; // No change needed
            }

            const newTagsLine = `tags: [${tagsArr.map(t => `"${t}"`).join(', ')}]`;
            mdEditor.value = content.replace(tagsRegex, newTagsLine);
        } else {
            // If no tags line found, try to insert it before the closing --- of frontmatter
            if (isChecked) {
                const frontmatterEnd = content.indexOf('---', 3);
                if (frontmatterEnd !== -1) {
                    const beforeEnd = content.substring(0, frontmatterEnd);
                    const afterEnd = content.substring(frontmatterEnd);
                    mdEditor.value = beforeEnd + `tags: ["精選"]\n` + afterEnd;
                }
            }
        }
    }

