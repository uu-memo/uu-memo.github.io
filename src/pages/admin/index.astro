                        </div>
                        <button id="toggle-list-btn-main" class="bg-uu-main text-white px-8 py-3 rounded-2xl font-bold text-sm hover:bg-uu-dark transition-all flex items-center gap-2 shadow-xl shadow-uu-main/20 active:scale-95">
